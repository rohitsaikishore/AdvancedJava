<?xml version="1.0" encoding="UTF-8"?>

<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xmlns:p="http://www.springframework.org/schema/p"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Customer Bean -->
    <bean name="customerBean" class="learning.Customer">
        <property name="name" value="this is Customer Name springboot"/>
        <property name="id" value="12345"/>
        <property name="address" value="hyderabad"/>
    </bean>

    <!-- Orders Bean using p-namespace -->
   <bean name="ordersBean" class="learning.Orders">
   
   <property name="orderId">
   <value>178</value>
   </property>
   
   <property name="productName" value="this is product Name"/>
   
   <property name="customer">
   		<ref bean="customerBean"></ref>
   </property>
   
   </bean>
   
   
</beans>